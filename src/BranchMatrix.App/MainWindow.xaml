<Window x:Class="BranchMatrix.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:BranchMatrix.App"
        mc:Ignorable="d"
        Title="BranchMatrix - 条件分岐チェックシート生成" Height="520" Width="820"
        AllowDrop="True" Drop="Window_Drop" DragOver="Window_DragOver">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 入力ファイル選択 -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="入力 .cs:" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <TextBox   Grid.Column="1" x:Name="PathBox" VerticalContentAlignment="Center" Height="28"/>
            <Button    Grid.Column="2" Content="参照..." Width="80" Height="28" Margin="8,0,0,0" Click="Browse_Click"/>
            <Button    Grid.Column="3" Content="解析" Width="80" Height="28" Margin="8,0,0,0" Click="Analyze_Click"/>
        </Grid>

        <TextBlock Grid.Row="1" Margin="0,8,0,4" Foreground="Gray"
                   Text="※ .cs ファイルをウィンドウにドラッグ＆ドロップしても読み込めます"/>

        <!-- メソッド一覧 -->
        <DataGrid Grid.Row="2" x:Name="MethodsGrid" AutoGenerateColumns="False" IsReadOnly="True"
                  HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                  CanUserAddRows="False" SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridTextColumn Header="メソッド" Binding="{Binding Name}" Width="200"/>
                <DataGridTextColumn Header="行" Binding="{Binding Line}" Width="60"/>
                <DataGridTextColumn Header="分岐数" Binding="{Binding DecisionCount}" Width="70"/>
                <DataGridTextColumn Header="シグネチャ" Binding="{Binding Signature}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <CheckBox Grid.Row="3" x:Name="IncludeEmptyBox" Margin="0,8,0,0"
                  Content="分岐なしのメソッドもシート化する"/>

        <!-- 出力 -->
        <Grid Grid.Row="4" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" x:Name="StatusText" VerticalAlignment="Center" Foreground="DimGray"/>
            <Button    Grid.Column="1" x:Name="ExportButton" Content="Excel出力..." Width="120" Height="32"
                       Click="Export_Click" IsEnabled="False"/>
        </Grid>
    </Grid>
</Window>
